# React frontend only. Set this to your Render backend URL on Vercel.
VITE_API_BASE=https://your-render-backend.onrender.com
VITE_CV_WEB_ENABLED=true
VITE_CV_LOCAL_WORKER_URL=http://127.0.0.1:8765
VITE_CV_DEFAULT_SOURCE_MODE=LIVE_CAMERA
VITE_CV_DEMO_ASSETS_ENABLED=true
VITE_HUB_OBSERVATION_FPS=2

CV_BACKEND_URL=http://127.0.0.1:8000
CV_WORKER_HOST=127.0.0.1
CV_WORKER_PORT=8765
CV_CAMERA_INDEX=0
CV_CAMERA_WIDTH=1280
CV_CAMERA_HEIGHT=720
CV_CONFIDENCE_THRESHOLD=0.75
CV_TARGET_INFERENCE_FPS=10
CV_DEVICE=auto
CV_PACKAGE_MODEL_PATH=models/cv/package_detector/v1/best.pt
CV_DAMAGE_MODEL_PATH=models/cv/damage_detector/v1/damage_detector.pth
CV_WEB_ENABLED=true
CV_PACKAGE_MODEL_URL=
CV_DAMAGE_MODEL_URL=
CV_PACKAGE_MODEL_SHA256=
CV_DAMAGE_MODEL_SHA256=
