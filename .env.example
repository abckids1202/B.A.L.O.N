LOGISENSE_DB_PATH=data/logisense.db
LOGISENSE_TIMEZONE=Asia/Jakarta
LOGISENSE_RANDOM_SEED=42

# React frontend only. Set this to your Render backend URL on Vercel.
VITE_API_BASE=https://your-render-backend.onrender.com

CV_BACKEND_URL=http://127.0.0.1:8000
CV_WORKER_HOST=127.0.0.1
CV_WORKER_PORT=8765
CV_CAMERA_INDEX=0
CV_CAMERA_WIDTH=1280
CV_CAMERA_HEIGHT=720
CV_CONFIDENCE_THRESHOLD=0.25
CV_TARGET_INFERENCE_FPS=10
CV_DEVICE=auto
CV_PACKAGE_MODEL_PATH=models/cv/package_detector/v1/best.pt
CV_DAMAGE_MODEL_PATH=models/cv/damage_detector/v1/best.pt
CV_EVENT_TOKEN=
CV_DEMO_TIME_MULTIPLIER=60
CV_EVENT_SNAPSHOT_ENABLED=true
CV_BACKEND_EVENT_ENABLED=true
